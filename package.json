{
  "name": "dobbi",
  "version": "3.0.4",
  "description": "An AI-powered Personal Assistant",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/index.js",
  "bin": {
    "dobbi": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "ai",
    "assistant",
    "cli",
    "todo",
    "notes",
    "personal-assistant",
    "openai",
    "anthropic",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/clift-labs/dobbi.git"
  },
  "license": "MIT",
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc && cp src/dobbi.txt dist/dobbi.txt && cp src/service/web-client.html dist/service/web-client.html",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --exclude='tests/integration/**'",
    "test:watch": "vitest --exclude='tests/integration/**'",
    "test:integration": "vitest run tests/integration",
    "test:all": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "inquirer": "^9.2.12",
    "marked": "^17.0.2",
    "node-ical": "^0.25.4",
    "openai": "^6.17.0",
    "ora": "^8.0.1",
    "ws": "^8.19.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
