{
  "name": "dobbie",
  "version": "1.0.0",
  "description": "AI-powered notes system with hierarchical context",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dobbie": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && cp src/dobbie.txt dist/dobbie.txt",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --exclude='tests/integration/**'",
    "test:watch": "vitest --exclude='tests/integration/**'",
    "test:integration": "vitest run tests/integration",
    "test:all": "vitest run",
    "build:binary": "npm run build && pkg . --out-path bin"
  },
  "pkg": {
    "targets": [
      "node18-macos-arm64"
    ],
    "outputPath": "bin",
    "assets": []
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "inquirer": "^9.2.12",
    "openai": "^6.17.0",
    "ora": "^8.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.0",
    "pkg": "^5.8.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}